{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without check_id returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET with non-existent id returns 404",
      "method": "GET",
      "path": "/?check_id=999999999",
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST creates local check (upstream may be unreachable in test env)",
      "method": "POST",
      "path": "/",
      "body": "{}",
      "expectedStatus": 200,
      "expectedBody": {"check_id": "string", "status": "string"},
      "bodyMatcher": "partial"
    }
  ]
}