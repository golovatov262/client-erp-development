{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without check_id returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST proxies to upstream (may timeout)",
      "method": "POST",
      "path": "/",
      "body": "{}",
      "expectedStatus": 504,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}